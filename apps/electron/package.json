{
  "name": "@repo-auditor/electron",
  "version": "0.2.0",
  "description": "Desktop shell for Repository Security Auditor",
  "author": "Fred Wang",
  "type": "module",
  "main": "build/main.js",
  "scripts": {
    "build": "tsc -p tsconfig.json && cp src/preload.cjs build/preload.cjs",
    "dev": "npm run build && electron .",
    "package:mac": "npm run build && electron-builder --mac",
    "package:win": "npm run build && electron-builder --win --x64",
    "package:linux": "npm run build && electron-builder --linux --x64",
    "package:all": "npm run build && electron-builder --mac --win --linux --x64",
    "test": "vitest run tests",
    "typecheck": "tsc -p tsconfig.test.json --noEmit"
  },
  "dependencies": {
    "@repo-auditor/ai-review": "0.2.0",
    "@repo-auditor/scanner-core": "0.2.0"
  },
  "devDependencies": {
    "electron": "31.7.7",
    "electron-builder": "^24.13.3"
  },
  "build": {
    "appId": "dev.repo-auditor.desktop",
    "productName": "Repository Security Auditor",
    "npmRebuild": false,
    "directories": {
      "output": "release"
    },
    "files": [
      "build/**",
      "src/renderer/index.html",
      "src/preload.cjs",
      "assets/**"
    ],
    "mac": {
      "target": "dmg",
      "icon": "assets/icon.png",
      "identity": null
    },
    "win": {
      "target": "nsis",
      "icon": "assets/icon.png"
    },
    "linux": {
      "target": "AppImage",
      "icon": "assets/icon.png"
    }
  }
}
